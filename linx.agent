#!/bin/bash
# Linx Telegram bot control
# Usage: ./bot.sh start | stop | status | logs | send "message"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLIST="$HOME/Library/LaunchAgents/com.ol.linx-telegram-bot.plist"

case "$1" in
  start)  launchctl bootout gui/$(id -u) "$PLIST" 2>/dev/null; launchctl bootstrap gui/$(id -u) "$PLIST" && echo "Bot started" ;;
  stop)   launchctl bootout gui/$(id -u) "$PLIST" 2>/dev/null && echo "Bot stopped" ;;
  restart) launchctl bootout gui/$(id -u) "$PLIST" 2>/dev/null; sleep 1; launchctl bootstrap gui/$(id -u) "$PLIST" && echo "Bot restarted" ;;
  status) launchctl list | grep linx-telegram > /dev/null && echo "Running" || echo "Stopped" ;;
  logs)   tail -f "$SCRIPT_DIR/.telegram-bot.log" ;;
  send)   bash "$SCRIPT_DIR/notify.sh" "$2" ;;
  *)      echo "Usage: linx.agent start|stop|restart|status|logs|send \"message\"" ;;
esac
